# ──────────────────────────────────────────────────────────────
# Aero — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────

# Discord webhook URL for the contact form serverless function.
# Generate a new one in Discord Server Settings → Integrations → Webhooks.
# Add this value as an environment variable in your Vercel project settings.
DISCORD_WEBHOOK_URL=

# Enter Analytics (optional — remove if not used)
VITE_ENTER_ANALYTICS_ENABLED=true
VITE_ENTER_ANALYTICS_TOKEN=
VITE_ENTER_PROJECT_ID=
VITE_ENTER_ANALYTICS_ENDPOINT=https://api.enter.pro
VITE_ENTER_ANALYTICS_DEFINITIONS_ENDPOINT=
VITE_ENTER_ANALYTICS_DEBUG=false
